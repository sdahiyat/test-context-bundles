# ============================================================
# NutriTrack — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# The public anonymous key (safe to expose to the browser).
# Row Level Security policies protect data access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# The secret service role key — BYPASSES RLS.
# Only use in server-side code (API routes, server components).
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── OpenAI ───────────────────────────────────────────────────
# Used for AI-powered food photo recognition and nutrition insights.
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ── Application ──────────────────────────────────────────────
# The canonical URL of the application (used for redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
