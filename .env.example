# =============================================================================
# NutriTrack — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Find these in your Supabase dashboard: Project Settings > API
# -----------------------------------------------------------------------------

# Supabase Project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key (safe to expose to the browser)
# Used for all client-side queries; RLS policies protect the data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — NEVER expose this to the client / browser.
# Only used in server-side API routes and Server Components.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# OpenAI
# https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------

# OpenAI API key for AI-powered food recognition
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Full public URL of the app (used for auth redirects, OG tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase Storage
# The 'meal-images' bucket is created automatically by migration 004.
# Image path convention: {user_id}/{timestamp}_{filename}
# Bucket name: meal-images
# -----------------------------------------------------------------------------
